		{
			"name": "[concat(parameters('factoryName'), '/Create_And_Populate_AccountsToDelete')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "Create AccountsToDelete Table",
						"type": "Script",
						"dependsOn": [
							{
								"activity": "Create_DeletedAccountsHistory_Table",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"linkedServiceName": {
							"referenceName": "BHDataArchiveDev",
							"type": "LinkedServiceReference"
						},
						"typeProperties": {
							"scripts": [
								{
									"type": "Query",
									"text": "IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[AccountsToDelete]') AND type in (N'U'))\nBEGIN\n    CREATE TABLE dbo.AccountsToDelete (\n        AccountId INT NOT NULL,\n        Source VARCHAR(50) NULL,  \n        DateInserted DATETIME DEFAULT GETDATE(),\n        CONSTRAINT PK_AccountsToDelete PRIMARY KEY (AccountId)\n    );\nEND"
								}
							],
							"scriptBlockExecutionTimeout": "02:00:00"
						}
					},
					{
						"name": "Create_DeletedAccountsHistory_Table",
						"type": "Script",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"linkedServiceName": {
							"referenceName": "BHDataArchiveDev",
							"type": "LinkedServiceReference"
						},
						"typeProperties": {
							"scripts": [
								{
									"type": "Query",
									"text": "IF NOT EXISTS (\n    SELECT 1 FROM sys.tables WHERE name = 'DeletedAccountsHistory'\n)\nBEGIN\n    CREATE TABLE dbo.DeletedAccountsHistory (\n        AccountId INT,\n        DateDeleted DATETIME DEFAULT GETDATE(),\n        CONSTRAINT PK_DeletedAccountsHistory PRIMARY KEY (AccountId)\n    );\nEND\n"
								}
							],
							"scriptBlockExecutionTimeout": "02:00:00"
						}
					},
					{
						"name": "Top_10_Accounts_Populate AccountsToDelete Table_copy1",
						"type": "Script",
						"dependsOn": [
							{
								"activity": "Create AccountsToDelete Table",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
