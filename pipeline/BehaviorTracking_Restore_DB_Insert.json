							"value": "select t1.* from (select  -- ap.* \nap.id\n,ap.childProfileid\n,ap.behaviorCategoryid\n,ap.[name]\n,ap.[definition]\n,ap.recordResultMethodType\n,ap.intervalsOfMinutes\n,ap.behaviorArchived\n,ap.dateCreated\n,ap.dateLastModified\n,ap.dateDeleted\n,ap.iep\n,ap.iepGoalChange\n,ap.iepGoalLocation\n,ap.iepGoalCurrentLevel\n,ap.iepGoalAnnualLevel\n,ap.dateArchived\n,ap.iepGoalChangeDefault\n,ap.iepGoalLocationDefault\n,ap.iepGoalCurrentLevelDefault\n,ap.iepGoalAnnualLevelDefault\n,ap.behaviorMastered\n,ap.iepGoalStudent\n,ap.consecutiveDays\n,ap.masteredDate\n,ap.StickyBaseline\n,ap.LearningProcessAttributesId\n,ap.recordResultMethodTypeSecondary\n,ap.FormTemplateId\n,ap.ReferenceBehaviorId\n,ap.pos\n,ap.lastMasteredDate\n,ap.switchedInterventionBy\n,ap.Justification\n,ap.SeverityIntensity\n,ap.SwitchedInterventionOn\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\n,ap.IsAutomastery\n,ap.IsAutomastered\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name}  ap \t\ninner join dbo.ChildProfile p on (ap.childProfileId=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')})\n)t1\nleft join Temp_BehaviorTracking t2 on t1.Id = t2.ID\nwhere t2.ID is null",
