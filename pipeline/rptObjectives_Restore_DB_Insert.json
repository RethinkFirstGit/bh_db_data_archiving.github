						"sqlReaderQuery": {
							"value": "\nselect t1.* from (select \nap.rptId\n,ap.ChildProfileId\n,ap.LessonId\n,ap.inCurrentPlan\n,ap.IepGoalId\n,ap.Iepgoal_DateDeleted\n,ap.IepObjectiveId\n,ap.Seq\n,ap.ObjectiveText\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.DateMastered\n,ap.masteryValue\n,ap.ObjectiveType\n,ap.ChildAccountInfoId\n,ap.ChildAccountType\n,ap.ChildL3AccountId\n,ap.ChildL2AccountId\n,ap.ChildL1AccountId\n,ap.MonthYear\n,ap.Year\n,ap.WeekYear\n,ap.WeekFirstDay\n,ap.DateMasteredMonthYear\n,ap.DateMasteredYear\n,ap.DateMasteredWeekYear\n,ap.DateMasteredWeekFirstDay\n,ap.DateMasteredChildAccountInfoId\n,ap.DateMasteredChildAccountType\n,ap.DateMasteredChildL3AccountId\n,ap.DateMasteredChildL2AccountId\n,ap.DateMasteredChildL1AccountId\n,ap.consecutiveDays\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap\n inner join dbo.ChildProfile c  on (ap.childprofileid=c.id)\n inner join accountinfo a on (c.accountinfoid=a.id)\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')})\n)t1\nleft join Temp_rptObjectives t2 on t1.rptId = t2.rptId\nWHERE t2.rptId IS NULL",
