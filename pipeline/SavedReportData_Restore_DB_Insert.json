				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (\nselect   ap.Id\n,ap.ReportId\n,ap.LessonId\n,ap.GoalText\n,ap.NoOfObjectivesMastered\n,ap.NoOfObjectives\n,ap.NoOfTargetsMastered\n,ap.NoOfTargets\n,ap.IEP\n,ap.CCSS\n,ap.LessonStatus\n,ap.LessonUserStatus\n,ap.ObjectiveId\n,ap.ObjectiveText\n,ap.ObjectiveSeq\n,ap.ObjectiveStatus\n,ap.ObjectiveUserStatus\n,ap.TargetId\n,ap.TargetName\n,ap.TargetStatus\n,ap.DataPointsInDateRange\n,ap.LastDataPointPercentage\n,ap.DataType\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.LessonNotes\n,ap.MeanPerformance\n,ap.StartDate\n,ap.DateMastered\n,ap.MinNumOfTrials\n,ap.MinPercentForTrial\n,ap.ConsecutiveSuccess\n,ap.PlanId\n,ap.PlanName\n,ap.PlanStartDate\n,ap.PlanEndDate\n,ap.LessonUserStatusText\n,ap.DataNoteCount\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap \ninner join SavedReports sr on (ap.Reportid=sr.id   )\ninner join dbo.ChildProfile p on (sr.childprofileid=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) --and  ap.IsMigrated = 0\n)t1\nleft join Temp_SavedReportData t2 on t1.Id = t2.ID\n\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
