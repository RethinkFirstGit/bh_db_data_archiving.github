				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "\nselect t1.* from (\nselect  ap.Id\n,ap.ReportId\n,ap.LessonId\n,ap.LessonCategory\n,ap.LessonName\n,ap.LessonMastered\n,ap.LessonMasteredDate\n,ap.MostRecentResult\n,ap.LessonDescription\n,ap.LessonInitiateDate\n,ap.DateInitiated\n,ap.StepsMastered\n,ap.CurrentStep\n,ap.CurrentStepMeanPerformance\n,ap.MasteryCriteriaNote\n,ap.ResponseMasteredNote\n,ap.CurrentStatusNote\n,ap.categoryIcon\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.CurrentTargetDesc\n,ap.CurrentTargetId\n from dbo.SavedReportDetails ap \ninner join dbo.SavedReports sr on ( ap.Reportid=sr.id    )  \ninner join dbo.ChildProfile p on (sr.childProfileId=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) --and  ap.IsMigrated = 0\n)t1\nleft join Temp_SavedReportDetails t2 on t1.Id = t2.ID\nWHERE t2.ID IS NULL\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
