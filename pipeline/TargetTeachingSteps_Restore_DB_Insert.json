							"value": "select a.* from (\nselect --ap.*\nap.id\n,ap.targetId\n,ap.teachingStepId\n,ap.definingStep\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap\ninner join dbo.TeachingStep ts on (ap.teachingStepId=ts.id  )\n inner join dbo.LearningProcessAttributes lp on (ts.LearningProcessAttributesId=lp.id)\n inner join dbo.CurrentCurriculum cc   on (ts.LearningProcessAttributesid=cc.id)\n inner join dbo.ChildProfile p on (cc.childprofileid=p.id )\ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) \n \n) a\nleft join Temp_TargetTeachingSteps b on a.Id = b.ID\nwhere b.ID is null",
