				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (select  --ap.* \nap.id\n,ap.StepNumber\n,ap.hollowChildProfileId\n,ap.hollowLessonId\n,ap.statusId\n,ap.[Description]\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.DateMastered\n,ap.hollowDateStarted\n,ap.levelId\n,ap.IepObjectiveId\n,ap.Active\n,ap.selected\n,ap.PretestSelected\n,ap.DateMasterable\n,ap.LearningProcessAttributesId\n,ap.correctPromptId\n,ap.IsMaintenanceOff\n,ap.DateMaintenanceMasterable\n,ap.DateMaintenanceMastered\n,ap.ReintroduceTargetId\n,ap.DateReintroduced\n,ap.TargetVersion\n,ap.Note\n,ap.DateLastScheduleChange\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\n,ap.IsMasteredManually\n,ap.DateManuallyOpened\n,ap.IsMasteredpreviously\n,ap.IsAutomastered\n,ap.IsMaintenanceAutomastered\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name}  ap \ninner join  dbo.IepObjective ij on (ap.iepobjectiveid=ij.id   )\ninner join  dbo.Iepgoal ig on (ij.Iepgoalid=ig.id   )\ninner join dbo.ChildProfile p on (ig.childprofileid=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) --and  ap.IsMigrated = 0\n)t1\nleft join Temp_ChildProfileLessonTarget t2 on t1.Id = t2.ID\nwhere t2.ID is null\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
