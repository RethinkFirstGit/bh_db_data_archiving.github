						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (select\nap.rptId\n,ap.ChildProfileId\n,ap.LessonId\n,ap.inCurrentPlan\n,ap.IepGoalId\n,ap.IepGoal_DateDeleted\n,ap.IepObjectiveId\n,ap.IepObjective_DateDeleted\n,ap.ChildProfileLessonTargetId\n,ap.StatusId\n,ap.Description\n,ap.ChildProfileLessonTarget_DateCreated\n,ap.ChildProfileLessonTarget_DateLastModified\n,ap.ChildProfileLessonTarget_DateDeleted\n,ap.ChildProfileLessonTarget_DateMastered\n,ap.Active\n,ap.ChildAccountInfoId\n,ap.ChildAccountType\n,ap.ChildL3AccountId\n,ap.ChildL2AccountId\n,ap.ChildL1AccountId\n,ap.MonthYear\n,ap.Year\n,ap.WeekYear\n,ap.WeekFirstDay\n,ap.DateMasteredMonthYear\n,ap.DateMasteredYear\n,ap.DateMasteredWeekYear\n,ap.DateMasteredWeekFirstDay\n,ap.DateMasteredChildAccountInfoId\n,ap.DateMasteredChildAccountType\n,ap.DateMasteredChildL3AccountId\n,ap.DateMasteredChildL2AccountId\n,ap.DateMasteredChildL1AccountId\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap\nINNER JOIN dbo.ChildProfile cp ON ap.childProfileId = cp.id\nINNER JOIN dbo.AccountInfo a ON cp.accountInfoId = a.ID\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')})\n--and  ap.IsMigrated = 0\n)t1\nleft join Temp_rptTargets t2 on t1.rptId = t2.rptId\nWhere t2.rptId IS NULL",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
