					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (select -- ap.* \n     ap.id\n     ,ap.planId\n     ,ap.behaviorTrackingId\n     ,ap.[date]\n     ,ap.numberOfMinutes\n     ,ap.numberOfTimesPerDay\n     ,ap.numberOfHoursObserved\n     ,ap.numberOfIntervalsOccured\n     ,ap.numberOfIntervalsObserved\n     ,ap.notes\n     ,ap.memberId\n     ,ap.dateCreated\n     ,ap.dateLastModified\n     ,ap.dateDeleted\n     ,ap.recordResultInd\n     ,ap.iepObjectiveId\n     ,ap.observedFrom\n     ,ap.observedTo\n     ,ap.invalidData\n     ,ap.errorMessage\n     ,ap.percentCorrect\n     ,ap.noCorrect\n     ,ap.noInCorrect\n     ,ap.hcAppointmentId\n     ,ap.ModifiedBy\n     ,ap.DeletedBy\n     ,ap.CreatedBy\n     ,ap.IsAutomastered\n     ,ap.StartDate\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name}  ap \tinner join behaviorTracking bt on (bt.Id=ap.behaviorTrackingId)\ninner join dbo.tblMember tm on (tm.id =ap.memberId    )\t\t\ninner join dbo.AccountInfo a on (tm.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')})\n\n)t1\nleft join Temp_BehaviorPlanDataRecording t2 on t1.Id = t2.ID\nwhere t2.ID is null\n\n\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
