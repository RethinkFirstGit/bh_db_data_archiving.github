						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (select  --ap.*\nap.id\n,ap.behaviorTrackingId\n,ap.childProfileId\n,ap.[name]\n,ap.dateCreated\n,ap.dateLastModified\n,ap.dateDeleted\n,ap.baseLinePlan\n,ap.ReviewNotes\n,ap.NewPlan\n,ap.baseLineStartDate\n,ap.baseLineEndDate\n,ap.baseLineNumberTimes\n,ap.baseLineInterval\n,ap.hasAssessments\n,ap.hasFunctions\n,ap.hasBaseline\n,ap.FunctionNotes\n,ap.NextReviewDate\n,ap.manuallyEntered\n,ap.FormResponseId\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap \t\ninner join dbo.ChildProfile p on (ap.childProfileId=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) \n\n)t1\nleft join Temp_BehaviorPlan\n t2 on t1.Id = t2.ID\nwhere t2.ID is null\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
