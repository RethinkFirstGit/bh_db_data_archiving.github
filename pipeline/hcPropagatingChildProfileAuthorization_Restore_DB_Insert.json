							"value": "select t1.* from (select  --ap.*\nap.id\n,ap.AuthorizationNumber\n,ap.hcChildProfileDiagnosisId\n,ap.hcAuthorizationRenderingProviderTypeId\n,ap.RenderingProviderStaffId\n,ap.NoOfUnits\n,ap.SchedulingGoalNoOfUnits\n,ap.CreatedBy\n,ap.DateCreated\n,ap.ModifiedBy\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.DiagnosisLUId\n,ap.EndDate\n,ap.hcChildProfileAuthorizationId\n,ap.hcChildProfileReferringProviderId\n,ap.DeletedBy\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap \n\t    inner join  dbo.hcChildProfileAuthorization cp  on (ap.hcChildProfileAuthorizationId=cp.id )\n\t\tinner join ChildProfile p on (cp.childprofileid=p.id ) \n        inner join AccountInfo a on (a.ID=p.accountInfoId  )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')})\n\n)t1\nleft join Temp_hcPropagatingChildProfileAuthorization t2 on t1.Id = t2.ID\nWHERE t2.ID IS NULL",
