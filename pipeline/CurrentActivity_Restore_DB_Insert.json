{
	"name": "CurrentActivity_Restore_DB_Insert",
	"properties": {
		"activities": [
			{
				"name": "CopydataCurrentActivity",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Copy data1",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (\nselect  --ap.* \nap.id\n,ap.childProfileId\n,ap.activityId\n,ap.[priority]\n,ap.statusId\n,ap.isAssigned\n,ap.DateMastered\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.DateAssigned\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap   \ninner join dbo.ChildProfile p on (ap.childprofileid=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) \n\n)t1\nleft join Temp_CurrentActivity t2 on t1.Id = t2.ID\nwhere t2.ID is null",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "Archive_DS_SourceDB",
