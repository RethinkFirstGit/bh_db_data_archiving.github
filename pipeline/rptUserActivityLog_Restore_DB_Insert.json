						"sqlReaderQuery": {
							"value": "select t1.* from (select ap.rptId\n,ap.DateLogged\n,ap.actionId\n,ap.memberId\n,ap.hollowSubscriberId\n,ap.childProfileId\n,ap.lessonId\n,ap.videoName\n,ap.resourceId\n,ap.TrainingTestId\n,ap.AccountInfoId\n,ap.behaviorTrackingId\n,ap.iep\n,ap.MemberAccountInfoId\n,ap.MemberAccountType\n,ap.MemberL3AccountId\n,ap.MemberL2AccountId\n,ap.MemberL1AccountId\n,ap.MonthYear\n,ap.Year\n,ap.WeekYear\n,ap.WeekFirstDay\n,ap.RowKey\n,ap.stepNo\n,ap.appVersion\n,ap.ModifiedBy\n,ap.DeletedBy\n,ap.CreatedBy\n,ap.DateDeleted\n,ap.DateLastModified\n,ap.DateCreated\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap \ninner join dbo.ChildProfile p on (ap.childProfileId=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) --and  ap.IsMigrated = 0\n)t1\nleft join Temp_rptUserActivityLog t2 on t1.rptId = t2.rptId\nWHERE t2.rptId IS NULL",
