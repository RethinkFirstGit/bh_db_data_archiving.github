				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (select \nt.id\n,t.Street1\n,t.Street2\n,t.City\n,t.StateId\n,t.Zip\n,t.CountryId\n,t.Town\n,t.ModifiedBy\n,t.DeletedBy\n,t.CreatedBy\n,t.DateDeleted\n,t.DateLastModified\n,t.DateCreated\nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} t\nWHERE EXISTS (\n    SELECT 1\n    FROM hcStaffMember s\n    JOIN tblMember m ON m.ID = s.tblMemberId\n    JOIN AccountInfo a ON a.ID = m.accountInfoId\n    WHERE s.AddressId = t.id\n    and a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) \n)\nOR EXISTS (\n    SELECT 1\n    FROM hcFunder f\n    JOIN AccountInfo a ON a.ID = f.accountInfoId\n     WHERE f.AddressId = t.id\n     and a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) )\nOR EXISTS (\n    SELECT 1\n    FROM hcChildProfileContacts cpc\n    JOIN ChildProfile cp ON cp.id = cpc.childProfileId\n    JOIN AccountInfo a ON a.ID = cp.accountInfoId\n    WHERE cpc.AddressId = t.id\n    and a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) )\nOR EXISTS (\n    SELECT 1\n    FROM hcChildProfileScheduleAssessment cpsa\n    JOIN ChildProfile cp ON cp.id = cpsa.childProfileId\n    JOIN AccountInfo a ON a.ID = cp.accountInfoId\n    WHERE cpsa.AddressId = t.id\n    and a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) )\nOR EXISTS (\n    SELECT 1\n    FROM hcProviderLocation pl\n    JOIN AccountInfo a ON pl.accountInfoId = a.ID\n    WHERE pl.AddressId = t.id\n    and a.Id in (@{join(pipeline().globalParameters.AccountID, ',')}) \n)\n)t1\nleft join Temp_hcAddress t2 on t1.Id = t2.ID\nwhere t2.ID is null",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
