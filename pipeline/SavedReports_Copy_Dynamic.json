						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select t1.* from (select ap.Id\n,ap.MemberId\n,ap.ChildProfileId\n,ap.ReportName\n,ap.StartDate\n,ap.EndDate\n,ap.LessonFilter\n,ap.LessonList\n,ap.showgraph\n,ap.showdetails\n,ap.shownotes\n,ap.showcc\n,ap.DateCreated\n,ap.DateLastModified\n,ap.DateDeleted\n,ap.Email\n,ap.SendToAddress\n,ap.EmailReportName\n,ap.ShowDataNotes \nfrom @{pipeline().parameters.Schema_Name}.@{pipeline().parameters.Table_Name} ap \ninner join dbo.ChildProfile p on (ap.childprofileid=p.id ) \ninner join dbo.AccountInfo a on (p.accountInfoId=a.ID )\nwhere a.Id in (@{join(pipeline().globalParameters.AccountID, ',')})\n--and ap.Ismigrated=0\n)t1\nleft join Temp_KareoInsuranceCompanies t2 on t1.Id = t2.ID\nWHERE t2.ID IS NULL\n\n\n\n\n\n\n\n\n",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
